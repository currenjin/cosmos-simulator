{
  "name": "cosmos-atlas",
  "version": "1.0.0",
  "description": "실제 하늘 시뮬레이터와 우주 물리 학습 랩을 제공하는 정적 웹앱입니다.",
  "main": "app.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "smoke:browser": "node scripts/playwright-smoke.js",
    "test:ui-state": "node scripts/playwright-ui-state-regression.js",
    "test:calc-regression": "node scripts/playwright-calculation-regression.js",
    "perf:snapshot": "node scripts/perf-snapshot.js",
    "perf:hud-throttle": "node scripts/hud-throttle-snapshot.js",
    "check:console": "bash scripts/console-checks.sh",
    "test": "npm run check:console && npm run smoke:browser && npm run test:ui-state && npm run test:calc-regression"
  },
  "repository": {
    "type": "git",
